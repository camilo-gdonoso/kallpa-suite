<%- include('../partials/header') %>

<main>
  <!-- Hero Section (Monday Style) -->
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">El motor de ejecución para tu <span>empresa</span></h1>
      <p class="hero-desc">Descubre <strong>Kallpa Suite</strong>: El ecosistema de gestión diseñado para equipos que necesitan control total, infraestructura propia y escalabilidad sin límites.</p>
      <div class="hero-actions">
        <button class="btn-solid" onclick="scrollToSection('contacto')" style="padding: 16px 48px; font-size: 16px;">Solicitar Demo</button>
        <p style="margin-top: 16px; font-size: 13px; color: var(--text-medium);">Infraestructura propia y soporte dedicado</p>
      </div>
    </div>
  </section>

  <!-- Dashboard Showcase (Static) -->
  <div class="showcase-container">
    <img src="/assets/dashboard_mockup.png" alt="Kallpa Suite Dashboard" class="showcase-img">
  </div>

  <!-- Live Demo Section (The Video) -->
  <section id="demo" class="section" style="padding-top: 0;">
    <div style="max-width: 1000px; margin: 0 auto; text-align: center;">
      <h2 class="section-title" style="margin-bottom: 24px;">Experimenta la <span>eficiencia</span> real</h2>
      <p style="font-size: 18px; color: var(--text-medium); margin-bottom: 48px;">Mira cómo Kallpa Suite transforma la gestión operativa en tiempo real.</p>
      
      <div class="browser-frame">
        <div class="browser-header">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
        </div>
        <img src="/assets/demo_tour.webp" alt="Kallpa Suite Demo Tour" style="width: 100%; display: block;">
      </div>
    </div>
  </section>

  <!-- Trusted By Section -->
  <section class="trust-section">
    <p class="trust-text">Potenciando empresas con tecnología de alto rendimiento</p>
    <div class="logo-grid">
      <div style="font-weight: 700; font-size: 24px; color: #323338;">INFRABOL</div>
      <i class="fas fa-industry"></i>
      <i class="fas fa-shipping-fast"></i>
      <i class="fas fa-hospital-user"></i>
      <i class="fas fa-store"></i>
    </div>
  </section>

  <!-- Value Propositions -->
  <section id="servicios" class="section">
    <h2 class="section-title">Módulos de <span>Gestión Integral</span></h2>
    <div class="grid">
      <!-- Módulo 1 -->
      <div class="card">
        <span class="module-tag">Producción</span>
        <div class="card-icon" style="background: #FFCB0020; color: #FFCB00;"><i class="fas fa-tasks"></i></div>
        <h3>Órdenes de Trabajo</h3>
        <p>Seguimiento detallado de obras en curso, gestión de estados (Kanban) y control de avance por proyecto.</p>
      </div>
      <!-- Módulo 2 -->
      <div class="card">
        <span class="module-tag">Logística</span>
        <div class="card-icon" style="background: #00CA7220; color: #00CA72;"><i class="fas fa-boxes"></i></div>
        <h3>Control de Inventario</h3>
        <p>Gestión de stock en tiempo real, alertas de reabastecimiento y vinculación directa con órdenes de compra.</p>
      </div>
      <!-- Módulo 3 -->
      <div class="card">
        <span class="module-tag">Inteligencia</span>
        <div class="card-icon" style="background: #FF047620; color: #FF0476;"><i class="fas fa-chart-line"></i></div>
        <h3>Monitor de Negocio</h3>
        <p>Reportes y resúmenes automáticos. Visualiza la salud de tu empresa con dashboards de alto impacto.</p>
      </div>
      <!-- Módulo 4 -->
      <div class="card">
        <span class="module-tag">Seguridad</span>
        <div class="card-icon" style="background: #6161FF20; color: #6161FF;"><i class="fas fa-user-shield"></i></div>
        <h3>Accesos y Roles (ERP)</h3>
        <p>Control total sobre quién ve qué. Gestión de planilla de personal y permisos granulares por módulo.</p>
      </div>
    </div>
  </section>

  <!-- Business Model Section -->
  <section id="modelo" class="section" style="background: #F5F6F8;">
    <div style="max-width: 1000px; margin: 0 auto; text-align: center;">
      <h2 class="section-title">Tecnología <span>Sostenible</span></h2>
      <p style="font-size: 20px; color: var(--text-medium); margin-bottom: 48px;">Olvídate de las suscripciones infinitas. Un modelo pensado para la rentabilidad de tu empresa.</p>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; text-align: left;">
        <div style="background: white; padding: 40px; border-radius: 16px; border-top: 4px solid var(--primary);">
          <h4 style="margin-bottom: 16px; font-size: 20px;">Infraestructura Anual</h4>
          <p style="color: var(--text-medium);">Pago único anual por el arriendo de tus servidores dedicados de alto rendimiento. Estabilidad y seguridad garantizada.</p>
        </div>
        <div style="background: white; padding: 40px; border-radius: 16px; border-top: 4px solid #00CA72;">
          <h4 style="margin-bottom: 16px; font-size: 20px;">Soporte y Evolución</h4>
          <p style="color: var(--text-medium);">Cuota anual de soporte que incluye actualizaciones, resolución de incidencias y ajustes para que tu suite nunca quede obsoleta.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Middle CTA Section -->
  <section class="section" style="background: #181B34; color: white; text-align: center;">
    <h2 style="font-size: 48px; margin-bottom: 24px;">Toma el control de tu operación</h2>
    <p style="font-size: 18px; margin-bottom: 40px; opacity: 0.8;">Únete a las empresas que ya operan con eficiencia real y costos inteligentes.</p>
    <button class="btn-solid" style="background: white; color: var(--primary); font-weight: 600;" onclick="scrollToSection('contacto')">Agendar una Consultoría</button>
  </section>

  <!-- Contact Form Section -->
  <section id="contacto" class="section">
    <div class="contact-container">
      <h2 class="section-title" style="margin-bottom: 16px;">Hablemos de tu <span>negocio</span></h2>
      <p style="text-align: center; margin-bottom: 40px; color: var(--text-medium);">Completa el formulario y un consultor de Kallpa Suite te contactará.</p>
      
      <form action="/api/contacto" method="POST">
        <input type="text" name="nombre" placeholder="Nombre completo" class="form-input" required>
        <input type="email" name="email" placeholder="Correo electrónico de trabajo" class="form-input" required>
        <textarea name="mensaje" placeholder="Cuéntanos sobre tus objetivos" class="form-input" rows="4" style="height: auto;"></textarea>
        <button type="submit" class="btn-solid" style="width: 100%; padding: 16px;">Enviar mensaje</button>
      </form>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
