<%- include('../partials/header') %>

<main class="section" style="text-align: center; padding: 150px 5%;">
  <div style="background: white; padding: 60px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
    <i class="fas fa-check-circle" style="font-size: 80px; color: #2ecc71; margin-bottom: 20px;"></i>
    <h1 style="margin-bottom: 10px;">¡Gracias, <%= nombre %>!</h1>
    <h2 style="margin-bottom: 20px; font-weight: 400; color: var(--text-muted);">Hemos recibido tu mensaje correctamente.</h2>
    <p style="margin-bottom: 40px; color: var(--text-muted);">Un consultor de Kallpa Marketing se pondrá en contacto contigo muy pronto.</p>
    <button class="btn-solid" onclick="window.location='/'">Volver al inicio</button>
  </div>
</main>

<%- include('../partials/footer') %>
